generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DRIVER
  OWNER
  ADMIN
}

enum SpaceType {
  LOT
  GARAGE
  DRIVEWAY
  STREET
}

enum SpaceStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  REJECTED
  DRAFT
}

enum RateType {
  HOURLY
  DAILY
  MONTHLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  name          String
  avatar        String?
  role          UserRole  @default(DRIVER)
  isVerified    Boolean   @default(false)
  isHost        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vehicles      Vehicle[]
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  notifications Notification[]

  @@index([role])
  @@index([isHost])
  @@index([createdAt])
}

model Vehicle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plateNumber String
  nickname    String?
  make        String?
  model       String?
  color       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  bookings    Booking[]

  @@unique([userId, plateNumber])
  @@index([userId])
}

model ParkingSpace {
  id             String      @id @default(cuid())
  hostId         String
  name           String
  description    String?
  address        String
  latitude       Float
  longitude      Float
  spaceType      SpaceType   @default(LOT)
  isCovered      Boolean     @default(false)
  isEvCharger    Boolean     @default(false)
  is247          Boolean     @default(false)
  heightLimit    Float?
  totalSpots     Int         @default(1)
  availableSpots Int         @default(1)
  status         SpaceStatus @default(PENDING_VERIFICATION)
  ratingAvg      Float       @default(0)
  ratingCount    Int         @default(0)
  primaryPhoto   String?
  hostName       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  images        ParkingImage[]
  pricing       ParkingPrice[]
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]

  @@index([hostId])
  @@index([status])
  @@index([spaceType])
  @@index([latitude, longitude])
  @@index([status, spaceType])
  @@index([status, createdAt])
  @@index([ratingAvg])
}

model ParkingImage {
  id        String       @id @default(cuid())
  spaceId   String
  space     ParkingSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean      @default(false)
  sortOrder Int          @default(0)

  @@index([spaceId])
  @@index([spaceId, isPrimary])
}

model ParkingPrice {
  id          String       @id @default(cuid())
  spaceId     String
  space       ParkingSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  rateType    RateType
  price       Float
  minDuration Int?
  maxDuration Int?

  @@index([spaceId])
  @@index([rateType])
}

model Booking {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId         String
  space           ParkingSpace   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  vehicleId       String?
  vehicle         Vehicle?       @relation(fields: [vehicleId], references: [id])
  vehiclePlate    String?
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int
  totalAmount     Float
  platformFee     Float          @default(0)
  hostPayout      Float          @default(0)
  status          BookingStatus  @default(PENDING)
  paymentStatus   PaymentStatus  @default(PENDING)
  bookingRef      String?        @unique
  qrCode          String?
  checkinTime     DateTime?
  checkoutTime    DateTime?
  cancelReason    String?
  cancelledAt     DateTime?
  createdAt       DateTime       @default(now())

  review          Review?

  @@index([userId])
  @@index([spaceId])
  @@index([status])
  @@index([paymentStatus])
  @@index([startTime])
  @@index([userId, status])
  @@index([spaceId, status])
}

model Review {
  id        String       @id @default(cuid())
  spaceId   String
  space     ParkingSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId String?      @unique
  booking   Booking?     @relation(fields: [bookingId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime     @default(now())

  @@unique([userId, spaceId])
  @@index([spaceId])
  @@index([rating])
  @@index([createdAt])
}

model Favorite {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId String
  space   ParkingSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([userId])
  @@index([spaceId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}
